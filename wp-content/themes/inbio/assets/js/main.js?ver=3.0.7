(function ($) {
  "use strict";

  var imJs = {
    m: function () {
      imJs.d();
      imJs.methods();
    },
    d: function () {
      this._window = $(window);
      this._document = $(document);
      this._body = $("body");
      this._html = $("html");
    },
    methods: function () {
      imJs.backToTopInit();
      imJs.wowActive();
      imJs.awsActivation();
      imJs.stickyAdjust();
      imJs._slickactivation();
      imJs.clapAnimation();
      imJs.swiperSlideronModal();
      imJs.portfolio_slick_activation();
    },

    // --- BEHOUDEN FUNCTIES ---

    backToTopInit: function () {
      var scrollTop = $(".backto-top");
      $(window).scroll(function () {
        $(scrollTop).css("opacity", $(this).scrollTop() > 250 ? "1" : "0");
      });
      $(scrollTop).on("click", function () {
        $("html, body").animate({ scrollTop: 0 }, 500);
      });
    },

    wowActive: function () {
      if (typeof WOW !== 'undefined') { new WOW().init(); }
    },

    awsActivation: function () {
      if (typeof AOS !== 'undefined') { setTimeout(function () { AOS.init(); }, 1000); }
    },

    stickyAdjust: function () {
      $(".rbt-sticky-top-adjust").css({ top: 120 });
      $(".rbt-sticky-top-adjust-two").css({ top: 100 });
      $(".rbt-sticky-top-adjust-three").css({ top: 50 });
      $(".header-sticky .rbt-sticky-top-adjust").css({ top: 160 });
    },

    _slickactivation: function () {
      $(".inbio-carousel-gallery").slick({
        infinite: false, slidesToShow: 1, slidesToScroll: 1, dots: true, arrows: true, adaptiveHeight: true,
        prevArrow: '<button class="slide-arrow prev-arrow"><i class="feather-arrow-left"></i></button>',
        nextArrow: '<button class="slide-arrow next-arrow"><i class="feather-arrow-right"></i></button>'
      });
    },

    portfolio_slick_activation: function () {
      $('.portfolio-slick-activation').slick({
        infinite: false, slidesToShow: 3, slidesToScroll: 1, dots: false, arrows: true, adaptiveHeight: true,
        prevArrow: '<button class="slide-arrow prev-arrow"><i class="feather-arrow-left"></i></button>',
        nextArrow: '<button class="slide-arrow next-arrow"><i class="feather-arrow-right"></i></button>',
        responsive: [
          { breakpoint: 1124, settings: { slidesToShow: 2 } },
          { breakpoint: 868, settings: { slidesToShow: 1 } },
          { breakpoint: 576, settings: { slidesToShow: 1, dots: true, arrows: false } }
        ]
      });
    },

    clapAnimation: function () {
      $(document).on("click", ".like-button", function () {
        var $btn = $(this);
        $btn.addClass("animate");
        setTimeout(function() { $btn.removeClass("animate"); }, 300);
      });
    },

    swiperSlideronModal: function () {
      $(document).on('shown.bs.modal', '.modal', function () {
        setTimeout(function () { window.dispatchEvent(new Event('resize')); }, 500);
      });
    }
  };

  imJs.m();
})(jQuery);