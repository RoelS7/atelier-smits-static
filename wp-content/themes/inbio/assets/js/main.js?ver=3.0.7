(function ($) {
    "use strict";

    $(document).ready(function () {
        // Activeer alle Bootstrap carrousels op de pagina
        $('.carousel').carousel({
            interval: 5000, // Wisselt elke 5 seconden
            pause: 'hover'  // Pauzeert als je eroverheen muist
        });

        // Zorg dat de eerste item zichtbaar is (Bootstrap heeft class 'active' nodig)
        $('.carousel-inner .carousel-item:first-child').addClass('active');
    });

})(jQuery, window);